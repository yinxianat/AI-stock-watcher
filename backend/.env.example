# ===== AI Stock Watcher: backend env =====
# Copy this file to `.env` and fill in real values for local dev.
# NEVER commit `.env` to git.

# --- App ---
APP_ENV=development                  # development | production | test
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_BASE_URL=http://localhost:5173

# --- Database ---
# Local dev defaults to a SQLite file. In production set DATABASE_URL to
# the Postgres connection string Railway provides (e.g. postgresql+psycopg://...).
DATABASE_URL=sqlite:///./dev.db

# --- Auth (magic link) ---
MAGIC_LINK_TTL_MINUTES=15
EMAIL_CONFIRM_TTL_MINUTES=60

# --- SMTP / Email ---
# For local dev, point this at Mailtrap, MailHog, or any other SMTP catcher.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=AI Stock Watcher <no-reply@example.com>
SMTP_USE_TLS=true

# --- Batch jobs ---
# Comma-separated cron-like HH:MM times in US/Eastern.
BATCH_JOB_TIMES_ET=09:35,12:30,16:05
BATCH_JOBS_ENABLED=true

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Logging & alerting ---
# Recipient for admin alerts (errors, signups, daily summary).
# Defaults to SMTP_USERNAME if blank.
ALERT_RECEIVER=
# Toggle alerts entirely (set false in CI / when SMTP is offline).
ALERTS_ENABLED=true
# Persist WARNING+ logs to the `log_entries` DB table.
LOG_DB_PERSISTENCE=true
# How long log rows are kept. Units: s/m/h/d/w/M/y (lowercase m = minutes,
# uppercase M = month ≈ 30 days). Bare integer = days. Examples: 24h, 7d,
# 30d, 1M, 90d, 1y.
LOG_LIFETIME=30d
# Daily summary email (HH:MM in US/Eastern). Default 17:30 — after the
# 16:05 batch completes.
DAILY_SUMMARY_TIME_ET=17:30
DAILY_SUMMARY_ENABLED=true

# --- Price history retention ---
# How long to keep DailyClose rows (the durable per-day closing-price
# history used to compute previous-day change and week/month/quarter/year
# extremes). Pruned daily by the cleanup job. Same units as LOG_LIFETIME.
# Default 365d — enough to compute a yearly low/high.
PRICE_HISTORY_LIFETIME=365d

# --- Intraday capture ---
# Capture latest price for every watched ticker on a fast cadence during
# US market hours. PRICE_CHANGE_RANGE rules fire on BOTH:
#   (a) tick-over-tick % (vs the price captured ~10 min ago), and
#   (b) day-over-day % (vs the previous trading day's close).
INTRADAY_INGEST_ENABLED=true
INTRADAY_TICK_MINUTES=10
# Retention for IntradayPrice rows (same units as LOG_LIFETIME). 7 days of
# 10-min ticks for ~50 watched tickers is ~14k rows — trivial.
INTRADAY_RETENTION=7d
# US-Eastern market hours window. Job exits early outside this window.
INTRADAY_MARKET_OPEN_ET=09:30
INTRADAY_MARKET_CLOSE_ET=16:00

# --- Stock-data provider ---
# "yfinance" (default; unofficial, breaks under Yahoo anti-bot crackdowns)
# or "finnhub" (official REST API, 60 calls/min on free tier, needs API key).
# Switch with no code changes if upstream becomes unreliable.
STOCK_DATA_PROVIDER=yfinance
FINNHUB_API_KEY=
